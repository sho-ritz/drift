{
  "name": "driftdocs",
  "version": "0.1.0",
  "description": "Keep specs and code provably in sync. A CodeGraph extension that links code symbols to spec sections, detects drift by hash comparison, and serves AI agents low-token context via MCP.",
  "keywords": [
    "documentation",
    "spec",
    "mcp",
    "codegraph",
    "ai-agents",
    "drift-detection",
    "obsidian"
  ],
  "type": "module",
  "bin": {
    "drift": "dist/main.js"
  },
  "main": "dist/main.js",
  "files": [
    "dist/main.js",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=esm --platform=node --target=node20 --external:better-sqlite3 --external:@modelcontextprotocol/sdk --external:zod --outfile=dist/main.js --banner:js='#!/usr/bin/env node' && node -e \"require('fs').chmodSync('dist/main.js', 0o755)\"",
    "prepublishOnly": "npm run build && rm -rf templates && cp -R ../../templates ./templates && cp ../../README.md ./README.md"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@driftdocs/core": "0.1.0",
    "@driftdocs/mcp": "0.1.0",
    "@types/node": "^22.0.0",
    "driftdocs": "^0.1.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
